{
  "name": "x402-xul-protocol",
  "version": "1.0.0",
  "description": "X402 Payment Protocol for XUL Chain - Open source implementation for micropayments and API monetization",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "hardhat test",
    "test:coverage": "hardhat coverage",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write src",
    "compile": "hardhat compile",
    "clean": "hardhat clean",
    "check-network": "tsx scripts/check-network.ts",
    "deploy:xul": "hardhat run scripts/deploy.ts --network xul-mainnet",
    "deploy:testnet": "hardhat run scripts/deploy.ts --network xul-testnet",
    "deploy:local": "hardhat run scripts/deploy.ts --network localhost",
    "verify": "hardhat verify --network xul-mainnet",
    "add-token": "hardhat run scripts/add-token.ts --network xul-mainnet"
  },
  "keywords": [
    "x402",
    "payment",
    "protocol",
    "xul-chain",
    "blockchain",
    "micropayment",
    "web3",
    "http-402"
  ],
  "author": "XUL Community",
  "license": "MIT",
  "dependencies": {
    "@openzeppelin/contracts": "^5.6.1",
    "axios": "^1.6.2",
    "dotenv": "^16.3.1",
    "ethers": "^6.10.0",
    "express": "^4.18.2"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.0.0",
    "@nomicfoundation/hardhat-ethers": "^3.0.0",
    "@nomicfoundation/hardhat-network-helpers": "^1.0.0",
    "@nomicfoundation/hardhat-toolbox": "^4.0.0",
    "@typechain/ethers-v6": "^0.5.0",
    "@typechain/hardhat": "^9.0.0",
    "@types/chai": "^4.2.0",
    "@types/express": "^4.17.21",
    "@types/mocha": ">=9.1.0",
    "@types/node": "^20.10.0",
    "@typescript-eslint/eslint-plugin": "^6.13.2",
    "@typescript-eslint/parser": "^6.13.2",
    "chai": "^4.2.0",
    "eslint": "^8.55.0",
    "hardhat": "^2.19.4",
    "hardhat-gas-reporter": "^1.0.8",
    "prettier": "^3.1.0",
    "solidity-coverage": "^0.8.0",
    "tsx": "^4.7.0",
    "typechain": "^8.3.0",
    "typescript": "^5.3.3",
    "vitest": "^1.0.4"
  }
}
